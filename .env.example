# Variables de entorno - Hotel System
# Copiar a .env y configurar valores reales

# Base de datos PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hotel_system
DB_USER=postgres
DB_PASSWORD=123456

# JWT
JWT_SECRET=cambiar_por_secreto_seguro_minimo_32_caracteres
JWT_EXPIRES_IN=8h

# Servidor
PORT=3001
NODE_ENV=development

# Hotel Info (se usa en facturas y reportes)
HOTEL_NAME=Hotel Ejemplo
HOTEL_ADDRESS=Calle Principal #123
HOTEL_PHONE=+00 000 000 0000
HOTEL_EMAIL=info@hotel.com
HOTEL_TAX_ID=000000000
HOTEL_TAX_RATE=0.16
